{
  "name": "coded-messages-app",
  "version": "0.2.0",
  "description": "Windows desktop obfuscated chat app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server:start": "node server/start.js",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.3",
    "pg": "^8.16.3",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.codedmessages.app",
    "productName": "Coded Messages",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "renderer/**/*",
      "server/**/*",
      "shared/**/*",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
