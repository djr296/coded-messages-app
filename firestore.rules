rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUid(uids) {
      return signedIn() && uids is list && uids.hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          "app_user_id",
          "uid",
          "email",
          "username",
          "username_lower",
          "profile_image_path",
          "last_seen_at",
          "updated_at"
        ])
        && request.resource.data.uid is string
        && request.resource.data.email is string
        && request.resource.data.username is string
        && request.resource.data.username_lower is string
        && request.resource.data.profile_image_path is string
        && request.resource.data.updated_at is string;
      allow delete: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.from_uid == request.auth.uid || resource.data.to_uid == request.auth.uid);
      allow create: if signedIn();
      allow update: if signedIn()
        && (resource.data.from_uid == request.auth.uid || resource.data.to_uid == request.auth.uid);
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if hasUid(resource.data.user_ids);
      allow create: if hasUid(request.resource.data.user_ids);
      allow update, delete: if hasUid(resource.data.user_ids);
    }

    match /conversations/{conversationId} {
      allow read: if hasUid(resource.data.member_ids);
      allow create: if hasUid(request.resource.data.member_ids)
        && request.resource.data.member_ids.hasAny([request.resource.data.created_by_user_id]);
      allow update: if hasUid(resource.data.member_ids) || hasUid(request.resource.data.member_ids);
      allow delete: if hasUid(resource.data.member_ids);
    }

    match /messages/{messageId} {
      allow read: if signedIn()
        && hasUid(get(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)).data.member_ids);
      allow create: if signedIn()
        && request.resource.data.sender_id == request.auth.uid
        && hasUid(get(/databases/$(database)/documents/conversations/$(request.resource.data.conversation_id)).data.member_ids);
      allow update, delete: if false;
    }

    match /groupInvites/{inviteId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.created_by_user_id == request.auth.uid;
      allow update: if signedIn()
        && resource.data.created_by_user_id == request.auth.uid;
      allow delete: if false;
    }

    match /blocks/{blockId} {
      allow read: if signedIn()
        && (resource.data.blocker_user_id == request.auth.uid || resource.data.blocked_user_id == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.blocker_user_id == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn()
        && resource.data.blocker_user_id == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if signedIn() && resource.data.reporter_user_id == request.auth.uid;
      allow create: if signedIn() && request.resource.data.reporter_user_id == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
